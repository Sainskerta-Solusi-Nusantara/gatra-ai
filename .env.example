# GATRA AI — On-premise AI Agent Platform configuration
# Copy to .env and fill in values. Never commit .env.

# ---- Core ----
NODE_ENV=production
GATRA_HOST=0.0.0.0
GATRA_PORT=7070
GATRA_DATA_DIR=./data
GATRA_LOG_LEVEL=info
GATRA_INSTANCE_ID=gatra-1

# ---- Database ----
# SQLite path; will be created if it does not exist
GATRA_DB_PATH=./data/gatra.db

# ---- LLM Provider ----
# Provider: anthropic | openai | claude-cli (subprocess)
GATRA_LLM_PROVIDER=anthropic
GATRA_LLM_MODEL=claude-sonnet-4-5
GATRA_LLM_MAX_TOKENS=4096
GATRA_LLM_TEMPERATURE=0.2

# Anthropic credentials (provider=anthropic)
ANTHROPIC_API_KEY=

# OpenAI credentials (provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude CLI path (provider=claude-cli) — fallback to subprocess execution
GATRA_CLAUDE_CLI_PATH=claude

# ---- Executor budget defaults ----
GATRA_DEFAULT_MAX_STEPS=50
GATRA_DEFAULT_MAX_TOKENS=200000
GATRA_DEFAULT_MAX_WALLCLOCK_SECONDS=86400
GATRA_DEFAULT_MAX_COST_USD=10

# ---- Session / supervisor ----
GATRA_SESSION_LEASE_TTL_MS=60000
GATRA_HEARTBEAT_INTERVAL_MS=15000
GATRA_MAX_CONCURRENT_RUNS=4
GATRA_SUPERVISOR_POLL_INTERVAL_MS=2000

# ---- Auth ----
# Static API token for the dashboard/REST API. Generate via `openssl rand -hex 32`.
GATRA_API_TOKEN=change-me-please-use-random-token

# ---- Dashboard ----
GATRA_DASHBOARD_DIR=./dashboard/dist
GATRA_CORS_ORIGIN=*

# ---- RBAC / auth ----
# JWT secret for /api/auth/login (HS256). Generate via `openssl rand -hex 32`.
GATRA_JWT_SECRET=
GATRA_JWT_EXPIRY_SECONDS=604800
GATRA_BOOTSTRAP_ADMIN_WA=+62-811-0000-0001
# Set to "true" to allow WA-number-only login (dev/pilot only).
GATRA_RBAC_OPEN_WA_LOGIN=false

# ---- Resignation / offboarding ----
# WA number to notify when a user resigns or is removed.
# Empty disables the notification hook.
RESIGNATION_NOTIFY_WA=
